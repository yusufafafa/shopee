# ===========================================
# AFFILIATE BOT CONFIGURATION
# ===========================================

# -------------------------------------------
# Telegram Bot Configuration
# -------------------------------------------
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (get from @userinfobot)
TELEGRAM_ADMIN_ID=

# -------------------------------------------
# Facebook Configuration
# -------------------------------------------
# Facebook cookie (format: c_user=xxx;xs=xxx;fr=xxx;...)
# Get using browser extension like EditThisCookie
FB_COOKIE=

# -------------------------------------------
# AI Configuration (OpenAI)
# -------------------------------------------
# OpenAI API key for text classification
AI_API_KEY=

# AI model to use
AI_MODEL=gpt-3.5-turbo

# -------------------------------------------
# Database Configuration
# -------------------------------------------
# SQLite database path
DATABASE_PATH=./data/affiliate.db

# -------------------------------------------
# Bot Settings
# -------------------------------------------
# Scan interval in seconds (default: 30)
SCAN_INTERVAL=30

# Delay between comments in seconds (default: 5)
COMMENT_DELAY=5

# Warm mode delay in seconds (default: 60)
# Use warm mode to avoid Facebook bans
WARM_MODE_DELAY=60

# -------------------------------------------
# Logging Configuration
# -------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO